meta {
  name: Untitled
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/images
  body: multipartForm
  auth: inherit
}

body:json {
  {
    "name": "testing name",
    "category": 1,
    "file"
  }
}

body:multipart-form {
  file: @file(/home/zach/Downloads/images.jpeg) @contentType(File)
  name: "name"
  category: 1
}

settings {
  encodeUrl: true
  timeout: 0
}
